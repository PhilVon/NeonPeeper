# Community Server Configuration

# Server identity
SERVER_ID=community-server-1
SERVER_NAME=Community Server
SERVER_DESCRIPTION=A Neon Peeper community server
SERVER_OWNER_ID=

# Network
PORT=8090
SIGNALING_URL=ws://localhost:8080

# Database backend: "sqlite" or "mysql"
DB_BACKEND=sqlite

# SQLite
SQLITE_PATH=./data/community.db

# MySQL (only used when DB_BACKEND=mysql)
MYSQL_HOST=localhost
MYSQL_PORT=3306
MYSQL_USER=neonpeeper
MYSQL_PASSWORD=
MYSQL_DATABASE=neon_community

# Comma-separated channels to auto-create on first run
DEFAULT_CHANNELS=general,random
