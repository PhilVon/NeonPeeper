{
  "name": "neon-template",
  "version": "0.0.2",
  "description": "Neon Aesthetic Electron + React + TypeScript Template",
  "author": {
    "name": "Neon Peeper",
    "email": "contact@neonpeeper.com"
  },
  "main": "dist/main/index.js",
  "scripts": {
    "dev": "vite",
    "build": "tsc && vite build",
    "preview": "vite preview",
    "build:linux": "npm run build && electron-builder --linux",
    "build:win": "npm run build && electron-builder --win"
  },
  "build": {
    "appId": "com.neon.peeper",
    "productName": "NeonPeeper",
    "directories": {
      "output": "release"
    },
    "files": [
      "dist/**/*",
      "package.json"
    ],
    "linux": {
      "target": [
        "AppImage",
        "deb",
        "pacman"
      ],
      "category": "Communication"
    },
    "win": {
      "target": [
        "nsis",
        "portable"
      ],
      "icon": "src/renderer/assets/logo.png"
    },
    "nsis": {
      "oneClick": false,
      "allowToChangeInstallationDirectory": true,
      "createDesktopShortcut": true,
      "createStartMenuShortcut": true
    }
  },
  "dependencies": {
    "@emoji-mart/data": "^1.2.1",
    "@emoji-mart/react": "^1.1.1",
    "@giphy/js-fetch-api": "^5.7.0",
    "@giphy/react-components": "^10.1.1",
    "@types/uuid": "^10.0.0",
    "idb": "^8.0.3",
    "react": "^18.2.0",
    "react-dom": "^18.2.0",
    "uuid": "^13.0.0",
    "zustand": "^4.5.0"
  },
  "devDependencies": {
    "@types/react": "^18.2.48",
    "@types/react-dom": "^18.2.18",
    "@vitejs/plugin-react": "^4.2.1",
    "electron": "^28.1.0",
    "electron-builder": "^26.8.1",
    "typescript": "^5.3.3",
    "vite": "^5.0.12",
    "vite-plugin-electron": "^0.28.0",
    "vite-plugin-electron-renderer": "^0.14.5"
  }
}